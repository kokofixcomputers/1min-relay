# Скопируйте в /etc/openclaw-bridge.env на LXC (права root:root 600).
# URL вашего 1min-relay (HTTPS или локальный прокси).
UPSTREAM_BASE_URL=https://api.example.com
# Слушать только loopback на машине с OpenClaw
BRIDGE_HOST=127.0.0.1
BRIDGE_PORT=8765
BRIDGE_UPSTREAM_TIMEOUT=120
# Защита от бесконечных циклов (token burn) при поломанных tool_calls
BRIDGE_LOOP_WINDOW_S=120
BRIDGE_LOOP_MAX_CALLS=3
# Универсальный “strict tools contract”: если модель заявляет про действия без tool_calls, bridge делает 1 строгий retry
BRIDGE_STRICT_TOOL_CONTRACT=1
# Фолбек модель для строгого retry (если дешёвая модель не умеет стабильно выдавать tool_calls)
# Можно оставить пустым, тогда retry будет на той же модели
# BRIDGE_TOOL_FALLBACK_MODEL=ratu/gpt-5-mini
# Опционально: общий секрет; тогда клиент передаёт заголовок X-Bridge-Secret
# BRIDGE_SECRET=
