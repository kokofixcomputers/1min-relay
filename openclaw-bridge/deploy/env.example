# Скопируйте в /etc/openclaw-bridge.env на LXC (права root:root 600).
# URL вашего 1min-relay (HTTPS или локальный прокси).
UPSTREAM_BASE_URL=https://api.example.com
# Слушать только loopback на машине с OpenClaw
BRIDGE_HOST=127.0.0.1
BRIDGE_PORT=8765
BRIDGE_UPSTREAM_TIMEOUT=120
# Опционально: общий секрет; тогда клиент передаёт заголовок X-Bridge-Secret
# BRIDGE_SECRET=
